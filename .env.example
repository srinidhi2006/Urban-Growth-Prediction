# ==============================================================================
# AI-Powered Urban Growth Prediction Platform - Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials/configurations.
# ==============================================================================

# --- Application Environment ---
ENV=development                  # development, staging, production
DEBUG=True                       # Enables debug logs and interactive errors
RANDOM_SEED=42                   # Ensures reproducibility across ML splits

# --- Google Earth Engine (GEE) Settings ---
GEE_PROJECT_ID=your-gee-cloud-project-id
# Optional: Use a Service Account JSON file instead of user authentication
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_PATH=

# --- OpenStreetMap (OSM) Ingestion Settings ---
OSM_TIMEOUT=180                  # Max request timeout in seconds
OSM_MAX_RETRIES=5                # Max retry count for OSM API failures

# --- Model & Training Parameters ---
DEFAULT_TRAIN_TEST_SPLIT=0.8     # Train-test ratio for cross-validation
EFFICIENTNET_BATCH_SIZE=32       # Batch size for deep learning feature extraction
NUM_WORKERS=4                    # Parallel CPU threads for data preprocessing

# --- FastAPI Server Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# --- Oracle Cloud Infrastructure (OCI) Deployment ---
OCI_CONFIG_PROFILE=DEFAULT
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your_compartment_ocid
OCI_DATA_SCIENCE_PROJECT_ID=ocid1.datascienceproject.oc1..your_project_ocid
OCI_BUCKET_NAME=urban-growth-data-bucket
OCI_MODEL_DEPLOYMENT_OCID=ocid1.datasciencemodeldeployment.oc1..your_deployment_ocid
